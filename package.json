{
  "name": "@alphasense-org/handoff-context",
  "version": "0.1.0",
  "description": "Floating annotation layer for React prototypes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite-plugin.js",
      "require": "./dist/vite-plugin.cjs",
      "types": "./dist/vite-plugin.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "prepare": "npm run build",
    "dev": "vite build --watch",
    "publish:gitlab": "npm publish"
  },
  "publishConfig": {
    "@alphasense-org:registry": "https://gitlab.com/api/v4/projects/82000158/packages/npm/"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
